<Window x:Class="DriverGuardian.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:localization="clr-namespace:DriverGuardian.UI.Wpf.Localization"
        xmlns:sections="clr-namespace:DriverGuardian.UI.Wpf.Views.Sections"
        mc:Ignorable="d"
        Title="{Binding State.TitleText}"
        Height="760"
        Width="1020"
        MinWidth="920"
        Background="#F1F5F9"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryWorkflowCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0 0 0 12" />
            <Setter Property="Background" Value="#F8FBFF" />
        </Style>

        <Style x:Key="PrimaryWorkflowInnerCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DBEAFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="SecondaryCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="11" />
            <Setter Property="Margin" Value="0 0 0 10" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style x:Key="PrimaryWorkflowCardStyleWhenNoScanDataVisible"
               TargetType="Border"
               BasedOn="{StaticResource PrimaryWorkflowCardStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryWorkflowInnerCardStyleWhenSecondarySummaryVisible"
               TargetType="Border"
               BasedOn="{StaticResource PrimaryWorkflowInnerCardStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State.Results.ShowSecondaryRecommendationSummary}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryWorkflowInnerCardStyleWhenRecommendationDetailsEmptyVisible"
               TargetType="Border"
               BasedOn="{StaticResource PrimaryWorkflowInnerCardStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State.Results.RecommendationDetails.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryWorkflowInnerCardStyleWhenUserGuidedStepsEmptyVisible"
               TargetType="Border"
               BasedOn="{StaticResource PrimaryWorkflowInnerCardStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Results.UserGuidedSteps.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryWorkflowInnerCardStyleWhenVerificationEmptyStateVisible"
               TargetType="Border"
               BasedOn="{StaticResource PrimaryWorkflowInnerCardStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Results.ShowVerificationEmptyState}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#BFD4EA" BorderThickness="1" CornerRadius="11" Padding="14" Background="#F8FBFF" Margin="0 0 0 12">
            <StackPanel>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 14 0">
                        <TextBlock Text="{Binding State.TitleText}" FontSize="22" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock Text="{Binding State.StatusText}" Margin="0 4 0 0" TextWrapping="Wrap" FontSize="14" Foreground="#1E293B" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{Binding State.ScanButtonText}"
                            Command="{Binding ScanCommand}"
                            Width="230"
                            Height="44"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="#2563EB"
                            BorderBrush="#1D4ED8"
                            BorderThickness="1.5" />
                </Grid>

                <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="7" Padding="10" Background="White">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.ScanOverviewTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding State.Results.ScanSummary}" Margin="0 0 0 4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.RecommendationSummary}" Margin="0 0 0 4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.ManualHandoffSummary}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="{Binding State.Results.ScanOverviewEmptyState}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="7" Padding="10" Margin="0 10 0 0" Background="#F5F9FF">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.ActionFlowTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.SafetyNotice}" TextWrapping="Wrap" Foreground="#1E293B" Margin="0 0 0 4"/>
                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepOpenOfficialSourceHint}" TextWrapping="Wrap" Foreground="#334155" Margin="0 0 0 4"/>
                        <TextBlock Text="{x:Static localization:UiStrings.VerificationSectionHint}" TextWrapping="Wrap" Foreground="#334155"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#FBBF24" BorderThickness="1" CornerRadius="7" Padding="10" Margin="0 10 0 0" Background="#FFFBEB">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.PreviewModeSectionTitle}" FontWeight="SemiBold" Margin="0 0 0 4"/>
                        <TextBlock Text="{Binding PreviewModeBannerText}" TextWrapping="Wrap" Margin="0 0 0 6"/>
                        <Grid Margin="0 0 0 6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.PreviewModeScenarioLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Width="380" HorizontalAlignment="Left" ItemsSource="{Binding AvailablePreviewScenarios}" SelectedItem="{Binding SelectedPreviewScenario}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <Button Content="{x:Static localization:UiStrings.PreviewApplyScenarioAction}" Width="260" Height="32" Command="{Binding ApplyPreviewScenarioCommand}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.25*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0 0 12 0">
                    <Border Style="{StaticResource PrimaryWorkflowCardStyleWhenNoScanDataVisible}">
                        <StackPanel>
                            <TextBlock Text="{Binding State.Results.WorkflowHeadline}" FontWeight="SemiBold" FontSize="17" Margin="0 0 0 4" Foreground="#1E3A8A"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHint}" Margin="0 0 0 8" TextWrapping="Wrap" Foreground="#1E293B"/>
                            <Border Style="{StaticResource PrimaryWorkflowInnerCardStyle}" Margin="0 0 0 6">
                                <TextBlock Text="{Binding State.Results.ScanOverviewEmptyState}" TextWrapping="Wrap" Foreground="#0F172A"/>
                            </Border>
                            <Border Style="{StaticResource PrimaryWorkflowInnerCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding State.Results.RecommendationSectionHint}" TextWrapping="Wrap" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding State.Results.ManualSectionHint}" TextWrapping="Wrap" Margin="0 4 0 0" Foreground="#334155"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PrimaryWorkflowCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding State.Results.ActionFlowTitle}" FontWeight="SemiBold" FontSize="17" Margin="0 0 0 4" Foreground="#1E3A8A"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHeadline}" FontWeight="SemiBold" Margin="0 0 0 4" TextWrapping="Wrap" Foreground="#0F172A"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHint}" Margin="0 0 0 8" TextWrapping="Wrap"/>
                            <UniformGrid Columns="3" Margin="0 0 0 8">
                                <Border Style="{StaticResource PrimaryWorkflowInnerCardStyle}" Padding="8" Margin="0 0 6 0">
                                    <StackPanel>
                                        <TextBlock Text="1" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepReviewRecommendation}" Margin="0 2 0 0" TextWrapping="Wrap" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource PrimaryWorkflowInnerCardStyle}" Padding="8" Margin="0 0 6 0">
                                    <StackPanel>
                                        <TextBlock Text="2" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepInstallOutsideApp}" Margin="0 2 0 0" TextWrapping="Wrap" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource PrimaryWorkflowInnerCardStyle}" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="3" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepReturnForVerification}" Margin="0 2 0 0" TextWrapping="Wrap" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="{Binding State.Results.SafetyNotice}" TextWrapping="Wrap" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>

                    <sections:RecommendationSectionView DataContext="{Binding WorkflowSection}" />
                    <sections:ManualActionSectionView DataContext="{Binding State}" />
                    <sections:VerificationSectionView DataContext="{Binding State}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <sections:ScanOverviewSectionView DataContext="{Binding State}" />

                    <sections:HistorySectionView DataContext="{Binding HistorySection}"/>

                    <sections:ReportSectionView />

                    <sections:SettingsSectionView />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
