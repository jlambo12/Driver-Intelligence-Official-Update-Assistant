<Window x:Class="DriverGuardian.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:localization="clr-namespace:DriverGuardian.UI.Wpf.Localization"
        mc:Ignorable="d"
        Title="{Binding State.TitleText}"
        Height="760"
        Width="940"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 10" Background="#FFFBEB">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{x:Static localization:UiStrings.PreviewModeSectionTitle}" FontWeight="SemiBold" Margin="0 0 0 4"/>
                <TextBlock Text="{Binding PreviewModeBannerText}" TextWrapping="Wrap" Margin="0 0 0 8"/>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.PreviewModeScenarioLabel}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              Width="420"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding AvailablePreviewScenarios}"
                              SelectedItem="{Binding SelectedPreviewScenario}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
                <Button Content="{x:Static localization:UiStrings.PreviewApplyScenarioAction}"
                        Width="260"
                        Height="34"
                        Command="{Binding ApplyPreviewScenarioCommand}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding State.StatusText}" FontSize="18" Margin="0 0 0 14" />
        <Button Grid.Row="2" Content="{Binding State.ScanButtonText}" Command="{Binding ScanCommand}" Width="220" Height="42" HorizontalAlignment="Left" Margin="0 0 0 10"/>

        <ScrollViewer Grid.Row="3" Margin="0 8 0 0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14" Background="#F8FAFC">
                    <StackPanel>
                        <TextBlock Text="{Binding State.Results.ActionFlowTitle}" FontWeight="SemiBold" FontSize="16" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.WorkflowHeadline}" FontWeight="SemiBold" Margin="0 0 0 4" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding State.Results.WorkflowHint}" Margin="0 0 0 8" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding State.Results.SafetyNotice}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.ScanOverviewTitle}" FontWeight="SemiBold" Margin="0 0 0 8"/>
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding State.Results.ScanSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.DiscoveryAndInspectionSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.RecommendationSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.ManualHandoffSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.OfficialSourceSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="{Binding State.Results.ScanOverviewEmptyState}" Margin="0 0 0 6" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14">
                    <StackPanel>
                        <TextBlock Text="{Binding State.Results.RecommendationSectionTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.RecommendationSectionHint}" Margin="0 0 0 8" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding State.Results.RecommendationDetails}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.RecommendationDetails.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0 0 0 8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding WorkflowState}" Margin="0 2 0 0" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding WorkflowStateHint}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DeviceSummary}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Summary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding InstalledDriverSummary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CandidateSummary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ManualHandoffSummary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding NextStepGuidance}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding State.Results.RecommendationEmptyState}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.RecommendationDetails.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14">
                    <StackPanel>
                        <TextBlock Text="{Binding State.Results.ManualSectionTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.ManualSectionHint}" Margin="0 0 0 8" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding State.Results.UserGuidedSteps}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.UserGuidedSteps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0 0 0 8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" TextWrapping="Wrap">
                                                <Run Text="• " />
                                                <Run Text="{Binding Title}" />
                                                <Run Text=" — " />
                                                <Run Text="{Binding Status}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding Description}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding State.Results.ManualSectionEmptyState}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.UserGuidedSteps.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14">
                    <StackPanel>
                        <TextBlock Text="{Binding State.Results.VerificationSectionTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.VerificationSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding State.Results.VerificationSectionHint}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding State.Results.VerificationRescanHint}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding State.Results.VerificationEmptyState}" Margin="0 6 0 0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.ShowVerificationEmptyState}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.RecentHistorySectionTitle}" FontWeight="SemiBold" Margin="0 0 0 4"/>
                        <TextBlock Text="{x:Static localization:UiStrings.RecentHistorySectionHint}" Margin="0 0 0 8" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding RecentHistory}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentHistory.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0 0 0 8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Timestamp}" Foreground="#475569" TextWrapping="Wrap"/>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Summary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Status}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Guidance}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{x:Static localization:UiStrings.RecentHistoryEmptyState}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentHistory.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 14">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.ReportExportTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{x:Static localization:UiStrings.ReportExportHint}" TextWrapping="Wrap" Margin="0 0 0 8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{x:Static localization:UiStrings.ReportExportAction}"
                                    Width="220"
                                    Height="34"
                                    Command="{Binding ExportReportCommand}" />
                            <TextBlock Text="{Binding ReportExportStatusText}" Margin="12 8 0 0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 10">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.SettingsTitle}" FontWeight="SemiBold" Margin="0 0 0 8"/>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsHistoryRetentionLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left" Text="{Binding HistoryMaxEntries}"/>
                        </Grid>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsReportFormatLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      Width="220"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding AvailableReportFormats}"
                                      SelectedItem="{Binding SelectedReportFormat}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <CheckBox Content="{x:Static localization:UiStrings.SettingsVerificationHintLabel}"
                                  IsChecked="{Binding ShowVerificationHints}"
                                  Margin="0 0 0 10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{x:Static localization:UiStrings.SettingsSaveAction}"
                                    Width="220"
                                    Height="34"
                                    Command="{Binding SaveSettingsCommand}" />
                            <TextBlock Text="{Binding SettingsStatusText}" Margin="12 8 0 0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
