<Window x:Class="DriverGuardian.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding State.TitleText}"
        Height="640"
        Width="860"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding State.StatusText}" FontSize="18" Margin="0 0 0 14" />
        <Button Grid.Row="1" Content="{Binding State.ScanButtonText}" Command="{Binding ScanCommand}" Width="220" Height="42" HorizontalAlignment="Left"/>

        <ScrollViewer Grid.Row="2" Margin="0 16 0 0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding State.Results.ScanSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding State.Results.DiscoveryAndInspectionSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding State.Results.RecommendationSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding State.Results.ManualHandoffSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding State.Results.VerificationSummary}" Margin="0 0 0 16" TextWrapping="Wrap"/>

                <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{Binding State.Results.ActionFlowTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.SafetyNotice}" Margin="0 0 0 10" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding State.Results.UserGuidedSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0 0 0 8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" TextWrapping="Wrap">
                                                <Run Text="• " />
                                                <Run Text="{Binding Title}" />
                                                <Run Text=" — " />
                                                <Run Text="{Binding Status}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding Description}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
