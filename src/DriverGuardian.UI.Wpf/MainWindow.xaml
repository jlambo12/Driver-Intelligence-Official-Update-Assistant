<Window x:Class="DriverGuardian.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:localization="clr-namespace:DriverGuardian.UI.Wpf.Localization"
        mc:Ignorable="d"
        Title="{Binding State.TitleText}"
        Height="760"
        Width="1020"
        MinWidth="920"
        Background="#F1F5F9"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#94A3B8"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Background="#F8FAFC"
                Margin="0 0 0 10">
            <StackPanel>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 14 0">
                        <TextBlock Text="{Binding State.TitleText}" FontSize="22" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock Text="{Binding State.StatusText}" Margin="0 4 0 0" TextWrapping="Wrap" FontSize="14" Foreground="#1E293B" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{Binding State.ScanButtonText}"
                            Command="{Binding ScanCommand}"
                            Width="230"
                            Height="44"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="#2563EB"
                            BorderBrush="#1D4ED8"
                            BorderThickness="1.5" />
                </Grid>

                <Border BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Background="White">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.ScanOverviewTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding State.Results.ScanSummary}" Margin="0 0 0 4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.RecommendationSummary}" Margin="0 0 0 4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.ManualHandoffSummary}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="{Binding State.Results.ScanOverviewEmptyState}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#C7D2FE"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0 8 0 0"
                        Background="#F8FAFF">
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.ActionFlowTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                        <TextBlock Text="{Binding State.Results.SafetyNotice}" TextWrapping="Wrap" Foreground="#1E293B" Margin="0 0 0 4"/>
                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepOpenOfficialSourceHint}" TextWrapping="Wrap" Foreground="#334155" Margin="0 0 0 4"/>
                        <TextBlock Text="{x:Static localization:UiStrings.VerificationSectionHint}" TextWrapping="Wrap" Foreground="#334155"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0 8 0 0" Background="#FFFBEB">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{x:Static localization:UiStrings.PreviewModeSectionTitle}" FontWeight="SemiBold" Margin="0 0 0 4"/>
                        <TextBlock Text="{Binding PreviewModeBannerText}" TextWrapping="Wrap" Margin="0 0 0 6"/>
                        <Grid Margin="0 0 0 6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.PreviewModeScenarioLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      Width="380"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding AvailablePreviewScenarios}"
                                      SelectedItem="{Binding SelectedPreviewScenario}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <Button Content="{x:Static localization:UiStrings.PreviewApplyScenarioAction}"
                                Width="260"
                                Height="32"
                                Command="{Binding ApplyPreviewScenarioCommand}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.25*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0 0 10 0">
                    <Border BorderBrush="#BFDBFE" BorderThickness="1.2" CornerRadius="7" Padding="12" Margin="0 0 0 10" Background="#F8FBFF">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding State.Results.WorkflowHeadline}" FontWeight="SemiBold" FontSize="17" Margin="0 0 0 4" Foreground="#1E3A8A"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHint}" Margin="0 0 0 8" TextWrapping="Wrap" Foreground="#1E293B"/>
                            <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Background="White" Padding="9" Margin="0 0 0 6">
                                <TextBlock Text="{Binding State.Results.ScanOverviewEmptyState}" TextWrapping="Wrap" Foreground="#0F172A"/>
                            </Border>
                            <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Background="White" Padding="9">
                                <StackPanel>
                                    <TextBlock Text="{Binding State.Results.RecommendationSectionHint}" TextWrapping="Wrap" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding State.Results.ManualSectionHint}" TextWrapping="Wrap" Margin="0 4 0 0" Foreground="#334155"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#BFDBFE" BorderThickness="1.2" CornerRadius="7" Padding="12" Margin="0 0 0 10" Background="#F8FBFF">
                        <StackPanel>
                            <TextBlock Text="{Binding State.Results.ActionFlowTitle}" FontWeight="SemiBold" FontSize="17" Margin="0 0 0 4" Foreground="#1E3A8A"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHeadline}" FontWeight="SemiBold" Margin="0 0 0 4" TextWrapping="Wrap" Foreground="#0F172A"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHint}" Margin="0 0 0 8" TextWrapping="Wrap"/>
                            <UniformGrid Columns="3" Margin="0 0 0 8">
                                <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Background="White" Padding="8" Margin="0 0 6 0">
                                    <StackPanel>
                                        <TextBlock Text="1" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepReviewRecommendation}" Margin="0 2 0 0" TextWrapping="Wrap" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Background="White" Padding="8" Margin="0 0 6 0">
                                    <StackPanel>
                                        <TextBlock Text="2" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepInstallOutsideApp}" Margin="0 2 0 0" TextWrapping="Wrap" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Background="White" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="3" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                        <TextBlock Text="{x:Static localization:UiStrings.ActionStepReturnForVerification}" Margin="0 2 0 0" TextWrapping="Wrap" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="{Binding State.Results.SafetyNotice}" TextWrapping="Wrap" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#FCD34D" BorderThickness="1.2" CornerRadius="7" Padding="12" Margin="0 0 0 10" Background="#FFFBEB">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding State.Results.HasScanData}" Value="True"/>
                                            <Condition Binding="{Binding State.Results.UserGuidedSteps.Count}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding State.Results.WorkflowHeadline}" FontWeight="SemiBold" FontSize="16" Foreground="#92400E" Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding State.Results.RecommendationEmptyState}" TextWrapping="Wrap" Foreground="#78350F" Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding State.Results.WorkflowHint}" TextWrapping="Wrap" Foreground="#78350F" Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding State.Results.VerificationRescanHint}" TextWrapping="Wrap" Foreground="#78350F"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#60A5FA" BorderThickness="1.4" CornerRadius="8" Padding="13" Margin="0 0 0 8" Background="#F0F7FF">
                        <StackPanel>
                            <DockPanel LastChildFill="True" Margin="0 0 0 6">
                                <Border DockPanel.Dock="Left"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="11"
                                        Background="#DBEAFE"
                                        Padding="0"
                                        Margin="0 0 8 0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"/>
                                </Border>
                                <TextBlock Text="{Binding State.Results.RecommendationSectionTitle}" FontWeight="SemiBold" FontSize="17" Foreground="#1E3A8A"/>
                            </DockPanel>
                            <TextBlock Text="{Binding State.Results.RecommendationSectionHint}" Margin="0 0 0 8" TextWrapping="Wrap" Foreground="#1E293B"/>
                            <ItemsControl ItemsSource="{Binding State.Results.RecommendationDetails}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.Results.RecommendationDetails.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0 0 0 6" Background="White">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding WorkflowState}" Margin="0 2 0 0" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding WorkflowStateHint}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DeviceSummary}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Summary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding InstalledDriverSummary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding CandidateSummary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding ManualHandoffSummary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding NextStepGuidance}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FFFFFF">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.Results.RecommendationDetails.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding State.Results.RecommendationEmptyState}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding State.Results.WorkflowHint}" Margin="0 4 0 0" TextWrapping="Wrap" Foreground="#334155"/>
                                    <TextBlock Text="{Binding State.Results.ManualSectionHint}" Margin="0 4 0 0" TextWrapping="Wrap" Foreground="#334155"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="↓"
                               FontSize="16"
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 8"/>

                    <Border BorderBrush="#BFDBFE" BorderThickness="1.2" CornerRadius="7" Padding="12" Margin="0 0 0 8" Background="#FCFDFF">
                        <StackPanel>
                            <DockPanel LastChildFill="True" Margin="0 0 0 6">
                                <Border DockPanel.Dock="Left"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="11"
                                        Background="#E0E7FF"
                                        Padding="0"
                                        Margin="0 0 8 0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="2"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"/>
                                </Border>
                                <TextBlock Text="{Binding State.Results.ManualSectionTitle}" FontWeight="SemiBold" FontSize="16" Foreground="#1E3A8A"/>
                            </DockPanel>
                            <TextBlock Text="{Binding State.Results.ManualSectionHint}" Margin="0 0 0 8" TextWrapping="Wrap" Foreground="#1E293B"/>
                            <ItemsControl ItemsSource="{Binding State.Results.UserGuidedSteps}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.Results.UserGuidedSteps.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0 0 0 6" Background="White">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" TextWrapping="Wrap">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding Title}" />
                                                    <Run Text=" — " />
                                                    <Run Text="{Binding Status}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="6" Padding="10" Background="#FFFFFF">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.Results.UserGuidedSteps.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding State.Results.ManualSectionEmptyState}" TextWrapping="Wrap" Foreground="#334155"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="↓"
                               FontSize="16"
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 8"/>

                    <Border BorderBrush="#93C5FD" BorderThickness="1.3" CornerRadius="7" Padding="12" Margin="0 0 0 10" Background="#F8FBFF">
                        <StackPanel>
                            <DockPanel LastChildFill="True" Margin="0 0 0 6">
                                <Border DockPanel.Dock="Left"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="11"
                                        Background="#E0F2FE"
                                        Padding="0"
                                        Margin="0 0 8 0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="3"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A"/>
                                </Border>
                                <TextBlock Text="{Binding State.Results.VerificationSectionTitle}" FontWeight="SemiBold" FontSize="16" Foreground="#1E3A8A"/>
                            </DockPanel>
                            <TextBlock Text="{Binding State.Results.VerificationSummary}" Margin="0 0 0 5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding State.Results.VerificationSectionHint}" Margin="0 0 0 4" TextWrapping="Wrap" Foreground="#1E293B"/>
                            <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="6" Padding="9" Background="White" Margin="0 0 0 4">
                                <TextBlock Text="{Binding State.Results.VerificationRescanHint}" TextWrapping="Wrap" Foreground="#0F172A"/>
                            </Border>
                            <Border BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="6" Padding="9" Background="White">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.Results.ShowVerificationEmptyState}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding State.Results.VerificationEmptyState}" TextWrapping="Wrap" Foreground="#334155"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="11" Margin="0 0 0 10" Background="#FFFFFF">
                        <StackPanel>
                            <TextBlock Text="{x:Static localization:UiStrings.ScanOverviewTitle}" FontWeight="SemiBold" Margin="0 0 0 8"/>
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.Results.HasScanData}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding State.Results.DiscoveryAndInspectionSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding State.Results.OfficialSourceSummary}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="11" Margin="0 0 0 10" Background="#FFFFFF">
                        <StackPanel>
                            <TextBlock Text="{x:Static localization:UiStrings.RecentHistorySectionTitle}" FontWeight="SemiBold" Margin="0 0 0 4"/>
                            <TextBlock Text="{x:Static localization:UiStrings.RecentHistorySectionHint}" Margin="0 0 0 6" TextWrapping="Wrap"/>
                            <ItemsControl ItemsSource="{Binding RecentHistory}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecentHistory.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="7" Margin="0 0 0 6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Timestamp}" Foreground="#475569" TextWrapping="Wrap"/>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Summary}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Status}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Guidance}" Margin="0 2 0 0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Static localization:UiStrings.RecentHistoryEmptyState}" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecentHistory.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="11" Margin="0 0 0 10" Background="#FFFFFF">
                        <StackPanel>
                            <TextBlock Text="{x:Static localization:UiStrings.ReportExportTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                            <TextBlock Text="{x:Static localization:UiStrings.ReportExportHint}" TextWrapping="Wrap" Margin="0 0 0 6"/>
                            <Button Content="{x:Static localization:UiStrings.ReportExportAction}"
                                    Width="220"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ExportReportCommand}" />
                            <TextBlock Text="{Binding ReportExportStatusText}" Margin="0 6 0 0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="11" Margin="0 0 0 6" Background="#FFFFFF">
                        <StackPanel>
                            <TextBlock Text="{x:Static localization:UiStrings.SettingsTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
                            <Grid Margin="0 0 0 6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsHistoryRetentionLabel}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left" Text="{Binding HistoryMaxEntries}"/>
                            </Grid>
                            <Grid Margin="0 0 0 6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="230"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsReportFormatLabel}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          Width="220"
                                          HorizontalAlignment="Left"
                                          ItemsSource="{Binding AvailableReportFormats}"
                                          SelectedItem="{Binding SelectedReportFormat}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <CheckBox Content="{x:Static localization:UiStrings.SettingsVerificationHintLabel}"
                                      IsChecked="{Binding ShowVerificationHints}"
                                      Margin="0 0 0 8"/>
                            <Button Content="{x:Static localization:UiStrings.SettingsSaveAction}"
                                    Width="220"
                                    Height="32"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SaveSettingsCommand}" />
                            <TextBlock Text="{Binding SettingsStatusText}" Margin="0 6 0 0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
