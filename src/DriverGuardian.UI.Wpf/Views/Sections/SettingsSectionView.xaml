<UserControl x:Class="DriverGuardian.UI.Wpf.Views.Sections.SettingsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="clr-namespace:DriverGuardian.UI.Wpf.Localization">
    <Border Style="{DynamicResource SecondaryCardStyle}" Margin="0 0 0 6">
        <StackPanel>
            <TextBlock Text="{x:Static localization:UiStrings.SettingsTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <Grid Margin="0 0 0 6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsHistoryRetentionLabel}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left" Text="{Binding SettingsSection.HistoryMaxEntries}"/>
            </Grid>
            <Grid Margin="0 0 0 6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsReportFormatLabel}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          Width="220"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding SettingsSection.AvailableReportFormats}"
                          SelectedItem="{Binding SettingsSection.SelectedReportFormat}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
            <CheckBox Content="{x:Static localization:UiStrings.SettingsVerificationHintLabel}"
                      IsChecked="{Binding SettingsSection.ShowVerificationHints}"
                      Margin="0 0 0 6"/>
            <Grid Margin="0 0 0 6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsScanProfileLabel}" Margin="0 0 8 0" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          Width="220"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding SettingsSection.AvailableScanProfiles}"
                          SelectedItem="{Binding SettingsSection.SelectedScanProfile}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
            <TextBlock Text="{x:Static localization:UiStrings.SettingsScanProfileHint}" Foreground="#475569" TextWrapping="Wrap" Margin="0 0 0 6"/>
            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0 0 0 8" Background="#F8FAFC">
                <StackPanel>
                    <CheckBox Content="{x:Static localization:UiStrings.SettingsDiagnosticLoggingLabel}"
                              IsChecked="{Binding SettingsSection.IsDiagnosticLoggingEnabled}"
                              Margin="0 0 0 4"/>
                    <TextBlock Text="{x:Static localization:UiStrings.SettingsDiagnosticLoggingHint}" Foreground="#475569" TextWrapping="Wrap" Margin="0 0 0 6"/>
                    <TextBlock Margin="0 0 0 8" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{x:Static localization:UiStrings.SettingsDiagnosticLoggingStateDisabled}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SettingsSection.IsDiagnosticLoggingEnabled}" Value="True">
                                        <Setter Property="Text" Value="{x:Static localization:UiStrings.SettingsDiagnosticLoggingStateEnabled}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Grid Margin="0 0 0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="230"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsDiagnosticCustomLogFolderLabel}" Margin="0 0 8 0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBox Grid.Column="1" Width="220" HorizontalAlignment="Left" Text="{Binding SettingsSection.CustomDiagnosticLogFolderPath}"/>
                    </Grid>
                    <TextBlock Text="{x:Static localization:UiStrings.SettingsDiagnosticCustomLogFolderHint}" Foreground="#475569" TextWrapping="Wrap" Margin="0 0 0 6"/>
                    <Grid Margin="0 0 0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="230"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static localization:UiStrings.SettingsDiagnosticEffectiveLogFolderLabel}" Margin="0 0 8 0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="1" Width="220" HorizontalAlignment="Left" Text="{Binding SettingsSection.EffectiveDiagnosticLogFolderPath}" TextWrapping="Wrap" Foreground="#334155"/>
                    </Grid>
                    <TextBlock Text="{x:Static localization:UiStrings.SettingsDiagnosticEffectiveLogFolderHint}" Foreground="#475569" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 0">
                <Button Content="{x:Static localization:UiStrings.SettingsSaveAction}"
                        Width="220"
                        Height="32"
                        HorizontalAlignment="Left"
                        Command="{Binding SettingsSection.SaveSettingsCommand}" />
                <Button Content="{x:Static localization:UiStrings.SettingsOpenLogsFolderAction}"
                        Width="170"
                        Height="32"
                        Margin="8 0 0 0"
                        HorizontalAlignment="Left"
                        Command="{Binding OpenDiagnosticLogsFolderCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding SettingsSection.SettingsStatusText}" Margin="0 6 0 0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
