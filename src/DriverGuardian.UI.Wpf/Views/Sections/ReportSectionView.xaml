<UserControl x:Class="DriverGuardian.UI.Wpf.Views.Sections.ReportSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="clr-namespace:DriverGuardian.UI.Wpf.Localization">
    <Border Style="{DynamicResource SecondaryCardStyle}">
        <StackPanel>
            <TextBlock Text="{x:Static localization:UiStrings.ReportExportTitle}" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBlock Text="{x:Static localization:UiStrings.ReportExportHint}" TextWrapping="Wrap" Margin="0 0 0 6"/>
            <Button Content="{x:Static localization:UiStrings.ReportExportAction}"
                    Width="220"
                    Height="32"
                    HorizontalAlignment="Left"
                    Command="{Binding ExportReportCommand}" />
            <TextBlock Text="{Binding ReportSection.ReportExportStatusText}" Margin="0 6 0 0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
